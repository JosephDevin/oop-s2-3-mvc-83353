@model IEnumerable<VgcCollege.Web.Models.Exam>
@{
    ViewData["Title"] = "Exams";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Exams</h2>
    @if (User.IsInRole("Administrator") || User.IsInRole("Faculty"))
    {
        <a asp-action="Create" class="btn btn-primary">+ New Exam</a>
    }
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Title</th>
                    <th>Course</th>
                    <th>Exam Date</th>
                    <th>Max Score</th>
                    <th>Released</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in Model)
                {
                    <tr>
                        <td class="fw-semibold">@e.Title</td>
                        <td>@e.Course?.Name</td>
                        <td>@e.ExamDate.ToString("dd MMM yyyy")</td>
                        <td>@e.MaxScore</td>
                        <td>
                            @if (e.ResultsReleased)
                            {
                                <span class="badge bg-success">Released</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Unreleased</span>
                            }
                        </td>
                        <td class="text-end">
                            @if (User.IsInRole("Administrator") || User.IsInRole("Faculty"))
                            {
                                <a asp-action="Details" asp-route-id="@e.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                                <a asp-action="Edit" asp-route-id="@e.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                                @if (User.IsInRole("Administrator"))
                                {
                                    <a asp-action="Delete" asp-route-id="@e.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                                }
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
