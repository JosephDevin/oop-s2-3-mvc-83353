@model VgcCollege.Web.Models.ExamResult
@{
    ViewData["Title"] = "Add Exam Result";
    var exam = ViewBag.Exam as VgcCollege.Web.Models.Exam;
}

<h2 class="mb-4">Add Result for: @exam?.Title</h2>
<p class="text-muted">Max Score: @exam?.MaxScore | Date: @exam?.ExamDate.ToString("dd MMM yyyy")</p>

<div class="card" style="max-width:500px">
    <div class="card-body">
        <form asp-action="AddResult" method="post">
            <input type="hidden" asp-for="ExamId" />
            <div class="mb-3">
                <label asp-for="StudentProfileId" class="form-label">Student</label>
                <select asp-for="StudentProfileId" asp-items="ViewBag.Students" class="form-select">
                    <option value="">-- Select Student --</option>
                </select>
                <span asp-validation-for="StudentProfileId" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Score" class="form-label">Score (max: @exam?.MaxScore)</label>
                <input asp-for="Score" class="form-control" type="number" step="0.01" max="@exam?.MaxScore" />
                <span asp-validation-for="Score" class="text-danger small"></span>
            </div>
            <p class="text-muted small">Grade will be auto-calculated. A=85%+, B=70%+, C=55%+, D=40%+, F=below 40%</p>
            <button type="submit" class="btn btn-success">Save Result</button>
            <a asp-action="Details" asp-route-id="@exam?.Id" class="btn btn-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
