@model IEnumerable<VgcCollege.Web.Models.AssignmentResult>
@{
    ViewData["Title"] = "My Assignment Results";
}

<h2 class="mb-4">My Assignment Results</h2>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Assignment</th>
                    <th>Course</th>
                    <th>Score</th>
                    <th>Max Score</th>
                    <th>Feedback</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td class="fw-semibold">@r.Assignment?.Title</td>
                        <td>@r.Assignment?.Course?.Name</td>
                        <td>@r.Score</td>
                        <td>@r.Assignment?.MaxScore</td>
                        <td>@(r.Feedback ?? "-")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
