@model IEnumerable<VgcCollege.Web.Models.Assignment>
@{
    ViewData["Title"] = "Assignments";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Assignments</h2>
    @if (User.IsInRole("Administrator") || User.IsInRole("Faculty"))
    {
        <a asp-action="Create" class="btn btn-primary">+ New Assignment</a>
    }
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Title</th>
                    <th>Course</th>
                    <th>Due Date</th>
                    <th>Max Score</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in Model)
                {
                    <tr>
                        <td class="fw-semibold">@a.Title</td>
                        <td>@a.Course?.Name</td>
                        <td>@a.DueDate.ToString("dd MMM yyyy")</td>
                        <td>@a.MaxScore</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@a.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                            @if (User.IsInRole("Administrator") || User.IsInRole("Faculty"))
                            {
                                <a asp-action="Edit" asp-route-id="@a.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                                <a asp-action="Delete" asp-route-id="@a.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
