@model VgcCollege.Web.Models.AttendanceRecord
@{
    ViewData["Title"] = "Edit Attendance Record";
}

<h2 class="mb-4">Edit Attendance Record</h2>

<div class="card" style="max-width:500px">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="mb-3">
                <label asp-for="CourseEnrolmentId" class="form-label">Enrolment</label>
                <select asp-for="CourseEnrolmentId" asp-items="ViewBag.CourseEnrolments" class="form-select"></select>
                <span asp-validation-for="CourseEnrolmentId" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="SessionDate" class="form-label"></label>
                <input asp-for="SessionDate" class="form-control" type="date" />
                <span asp-validation-for="SessionDate" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="WeekNumber" class="form-label"></label>
                <input asp-for="WeekNumber" class="form-control" type="number" min="1" max="52" />
                <span asp-validation-for="WeekNumber" class="text-danger small"></span>
            </div>
            <div class="mb-3 form-check">
                <input asp-for="Present" class="form-check-input" type="checkbox" />
                <label asp-for="Present" class="form-check-label">Present</label>
            </div>
            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
