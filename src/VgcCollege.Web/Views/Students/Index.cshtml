@model IEnumerable<VgcCollege.Web.Models.StudentProfile>
@{
    ViewData["Title"] = User.IsInRole("Administrator") ? "All Students" : "My Students";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>@ViewData["Title"]</h2>
    @if (User.IsInRole("Administrator"))
    {
        <a asp-action="Create" class="btn btn-primary">+ New Student</a>
    }
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Student #</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Enrolments</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model)
                {
                    <tr>
                        <td><code>@s.StudentNumber</code></td>
                        <td class="fw-semibold">@s.Name</td>
                        <td>@s.Email</td>
                        <td><span class="badge bg-secondary">@s.Enrolments.Count</span></td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@s.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                            @if (User.IsInRole("Administrator"))
                            {
                                <a asp-action="Edit" asp-route-id="@s.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                                <a asp-action="Delete" asp-route-id="@s.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
