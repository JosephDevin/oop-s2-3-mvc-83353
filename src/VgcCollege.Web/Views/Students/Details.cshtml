@model VgcCollege.Web.Models.StudentProfile
@{
    ViewData["Title"] = "Student Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>@Model.Name</h2>
    <div>
        @if (User.IsInRole("Administrator"))
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary">Edit</a>
        }
        <a asp-action="Index" class="btn btn-secondary ms-2">Back</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card">
            <div class="card-header fw-semibold">Personal Details</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-5">Student #</dt>
                    <dd class="col-7"><code>@Model.StudentNumber</code></dd>
                    <dt class="col-5">Email</dt>
                    <dd class="col-7">@Model.Email</dd>
                    <dt class="col-5">Phone</dt>
                    <dd class="col-7">@(Model.Phone ?? "-")</dd>
                    <dt class="col-5">DOB</dt>
                    <dd class="col-7">@Model.DateOfBirth.ToString("dd MMM yyyy")</dd>
                    <dt class="col-5">Address</dt>
                    <dd class="col-7">@(Model.Address ?? "-")</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card">
            <div class="card-header fw-semibold">Enrolments</div>
            <div class="table-responsive">
                <table class="table table-sm mb-0">
                    <thead class="table-light">
                        <tr><th>Course</th><th>Branch</th><th>Enrol Date</th><th>Status</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var e in Model.Enrolments)
                        {
                            <tr>
                                <td>@e.Course?.Name</td>
                                <td>@e.Course?.Branch?.Name</td>
                                <td>@e.EnrolDate.ToString("dd MMM yyyy")</td>
                                <td><span class="badge bg-@(e.Status == VgcCollege.Web.Models.EnrolmentStatus.Active ? "success" : e.Status == VgcCollege.Web.Models.EnrolmentStatus.Withdrawn ? "danger" : "secondary")">@e.Status</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
