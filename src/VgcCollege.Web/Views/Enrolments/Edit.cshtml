@model VgcCollege.Web.Models.CourseEnrolment
@{
    ViewData["Title"] = "Edit Enrolment";
}

<h2 class="mb-4">Edit Enrolment</h2>

<div class="card" style="max-width:500px">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="mb-3">
                <label asp-for="StudentProfileId" class="form-label">Student</label>
                <select asp-for="StudentProfileId" asp-items="ViewBag.Students" class="form-select"></select>
                <span asp-validation-for="StudentProfileId" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="CourseId" class="form-label">Course</label>
                <select asp-for="CourseId" asp-items="ViewBag.Courses" class="form-select"></select>
                <span asp-validation-for="CourseId" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="EnrolDate" class="form-label"></label>
                <input asp-for="EnrolDate" class="form-control" type="date" />
                <span asp-validation-for="EnrolDate" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Status" class="form-label"></label>
                <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<VgcCollege.Web.Models.EnrolmentStatus>()"></select>
            </div>
            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
