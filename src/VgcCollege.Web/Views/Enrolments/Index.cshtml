@model IEnumerable<VgcCollege.Web.Models.CourseEnrolment>
@{
    ViewData["Title"] = "Enrolments";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Enrolments</h2>
    @if (User.IsInRole("Administrator"))
    {
        <a asp-action="Create" class="btn btn-primary">+ Enrol Student</a>
    }
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Student</th>
                    <th>Course</th>
                    <th>Branch</th>
                    <th>Enrol Date</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in Model)
                {
                    <tr>
                        <td class="fw-semibold">@e.StudentProfile?.Name</td>
                        <td>@e.Course?.Name</td>
                        <td><span class="badge bg-secondary">@e.Course?.Branch?.Name</span></td>
                        <td>@e.EnrolDate.ToString("dd MMM yyyy")</td>
                        <td><span class="badge bg-@(e.Status == VgcCollege.Web.Models.EnrolmentStatus.Active ? "success" : e.Status == VgcCollege.Web.Models.EnrolmentStatus.Withdrawn ? "danger" : "secondary")">@e.Status</span></td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@e.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                            @if (User.IsInRole("Administrator"))
                            {
                                <a asp-action="Edit" asp-route-id="@e.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                                <a asp-action="Delete" asp-route-id="@e.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
