@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Administrator Dashboard</h2>
    <span class="badge bg-danger fs-6">Administrator</span>
</div>

<div class="row g-4 mb-4">
    <div class="col-sm-6 col-xl-2-4">
        <div class="card text-white bg-primary h-100">
            <div class="card-body">
                <h5 class="card-title">Branches</h5>
                <p class="display-5 fw-bold mb-0">@ViewBag.BranchCount</p>
            </div>
            <div class="card-footer">
                <a class="text-white text-decoration-none small" asp-controller="Branches" asp-action="Index">Manage &rarr;</a>
            </div>
        </div>
    </div>
    <div class="col-sm-6">
        <div class="card text-white bg-success h-100">
            <div class="card-body">
                <h5 class="card-title">Courses</h5>
                <p class="display-5 fw-bold mb-0">@ViewBag.CourseCount</p>
            </div>
            <div class="card-footer">
                <a class="text-white text-decoration-none small" asp-controller="Courses" asp-action="Index">Manage &rarr;</a>
            </div>
        </div>
    </div>
    <div class="col-sm-6">
        <div class="card text-white bg-info h-100">
            <div class="card-body">
                <h5 class="card-title">Students</h5>
                <p class="display-5 fw-bold mb-0">@ViewBag.StudentCount</p>
            </div>
            <div class="card-footer">
                <a class="text-white text-decoration-none small" asp-controller="Students" asp-action="Index">Manage &rarr;</a>
            </div>
        </div>
    </div>
    <div class="col-sm-6">
        <div class="card text-white bg-warning h-100">
            <div class="card-body">
                <h5 class="card-title">Faculty</h5>
                <p class="display-5 fw-bold mb-0">@ViewBag.FacultyCount</p>
            </div>
            <div class="card-footer">
                <a class="text-white text-decoration-none small" asp-controller="Faculty" asp-action="Index">Manage &rarr;</a>
            </div>
        </div>
    </div>
    <div class="col-sm-6">
        <div class="card text-white bg-secondary h-100">
            <div class="card-body">
                <h5 class="card-title">Active Enrolments</h5>
                <p class="display-5 fw-bold mb-0">@ViewBag.EnrolmentCount</p>
            </div>
            <div class="card-footer">
                <a class="text-white text-decoration-none small" asp-controller="Enrolments" asp-action="Index">Manage &rarr;</a>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card">
            <div class="card-header bg-light fw-semibold">Quick Actions</div>
            <div class="list-group list-group-flush">
                <a asp-controller="Enrolments" asp-action="Create" class="list-group-item list-group-item-action">Enrol Student</a>
                <a asp-controller="Exams" asp-action="Index" class="list-group-item list-group-item-action">Manage Exam Results</a>
                <a asp-controller="Attendance" asp-action="Create" class="list-group-item list-group-item-action">Record Attendance</a>
                <a asp-controller="Faculty" asp-action="Index" class="list-group-item list-group-item-action">Faculty Assignments</a>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-light fw-semibold">System Overview</div>
            <div class="card-body">
                <p class="text-muted">Acme Global College (VGC) multi-branch student and course management system.</p>
                <ul class="list-unstyled mb-0">
                    <li><span class="badge bg-primary me-2">Dublin City</span>Main campus in Dublin 1</li>
                    <li class="mt-1"><span class="badge bg-success me-2">Cork Campus</span>South campus, Cork City</li>
                    <li class="mt-1"><span class="badge bg-warning text-dark me-2">Galway Campus</span>West campus, Galway City</li>
                </ul>
            </div>
        </div>
    </div>
</div>
