@{
    ViewData["Title"] = "Faculty Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Welcome, @ViewBag.FacultyName</h2>
    <span class="badge bg-info fs-6">Faculty</span>
</div>

<div class="row g-4 mb-4">
    <div class="col-sm-6">
        <div class="card text-white bg-primary h-100">
            <div class="card-body">
                <h5 class="card-title">My Courses</h5>
                <p class="display-5 fw-bold mb-0">@ViewBag.CourseCount</p>
            </div>
            <div class="card-footer">
                <a class="text-white text-decoration-none small" asp-controller="Courses" asp-action="Index">View Courses &rarr;</a>
            </div>
        </div>
    </div>
    <div class="col-sm-6">
        <div class="card text-white bg-success h-100">
            <div class="card-body">
                <h5 class="card-title">Active Students</h5>
                <p class="display-5 fw-bold mb-0">@ViewBag.StudentCount</p>
            </div>
            <div class="card-footer">
                <a class="text-white text-decoration-none small" asp-controller="Students" asp-action="Index">View Students &rarr;</a>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-light fw-semibold">Quick Actions</div>
            <div class="list-group list-group-flush">
                <a asp-controller="Attendance" asp-action="Create" class="list-group-item list-group-item-action">Record Attendance</a>
                <a asp-controller="Assignments" asp-action="Index" class="list-group-item list-group-item-action">View Assignments</a>
                <a asp-controller="Exams" asp-action="Index" class="list-group-item list-group-item-action">View Exams</a>
                <a asp-controller="Enrolments" asp-action="Index" class="list-group-item list-group-item-action">View Enrolments</a>
            </div>
        </div>
    </div>
</div>
