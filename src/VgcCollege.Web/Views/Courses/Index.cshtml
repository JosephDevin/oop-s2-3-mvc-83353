@model IEnumerable<VgcCollege.Web.Models.Course>
@{
    ViewData["Title"] = "Courses";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Courses</h2>
    @if (User.IsInRole("Administrator"))
    {
        <a asp-action="Create" class="btn btn-primary">+ New Course</a>
    }
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Branch</th>
                    <th>Start</th>
                    <th>End</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var course in Model)
                {
                    <tr>
                        <td class="fw-semibold">@course.Name</td>
                        <td><span class="badge bg-secondary">@course.Branch?.Name</span></td>
                        <td>@course.StartDate.ToString("dd MMM yyyy")</td>
                        <td>@course.EndDate.ToString("dd MMM yyyy")</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@course.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                            @if (User.IsInRole("Administrator"))
                            {
                                <a asp-action="Edit" asp-route-id="@course.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                                <a asp-action="Delete" asp-route-id="@course.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
