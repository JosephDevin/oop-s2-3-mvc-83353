@model VgcCollege.Web.Models.FacultyProfile
@{
    ViewData["Title"] = "Faculty Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>@Model.Name</h2>
    <div>
        <a asp-action="AssignCourse" asp-route-id="@Model.Id" class="btn btn-success">Assign Course</a>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary ms-2">Edit</a>
        <a asp-action="Index" class="btn btn-secondary ms-2">Back</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card">
            <div class="card-header fw-semibold">Details</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-4">Name</dt>
                    <dd class="col-8">@Model.Name</dd>
                    <dt class="col-4">Email</dt>
                    <dd class="col-8">@Model.Email</dd>
                    <dt class="col-4">Phone</dt>
                    <dd class="col-8">@(Model.Phone ?? "-")</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card">
            <div class="card-header fw-semibold">Assigned Courses</div>
            <div class="table-responsive">
                <table class="table table-sm mb-0">
                    <thead class="table-light">
                        <tr><th>Course</th><th>Branch</th><th></th></tr>
                    </thead>
                    <tbody>
                        @foreach (var a in Model.CourseAssignments)
                        {
                            <tr>
                                <td>@a.Course?.Name</td>
                                <td>@a.Course?.Branch?.Name</td>
                                <td class="text-end">
                                    <form asp-action="RemoveCourseAssignment" method="post" style="display:inline">
                                        <input type="hidden" name="assignmentId" value="@a.Id" />
                                        <input type="hidden" name="facultyId" value="@Model.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
