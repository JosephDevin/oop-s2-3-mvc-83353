@model IEnumerable<VgcCollege.Web.Models.FacultyProfile>
@{
    ViewData["Title"] = "Faculty";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Faculty</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Faculty</a>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Courses</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var f in Model)
                {
                    <tr>
                        <td class="fw-semibold">@f.Name</td>
                        <td>@f.Email</td>
                        <td>@(f.Phone ?? "-")</td>
                        <td><span class="badge bg-secondary">@f.CourseAssignments.Count</span></td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@f.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                            <a asp-action="Edit" asp-route-id="@f.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                            <a asp-action="Delete" asp-route-id="@f.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
